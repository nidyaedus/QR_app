generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  name       String
  phone      String   @unique
  stampCount Int      @default(0)
  orders     Order[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  address   String
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  category    String // e.g. "Coffee", "Cold Brew", "Snacks"
  imageUrl    String?
  orderItems  OrderItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id])
  status      String   @default("RECEIVED") // RECEIVED, PREPARING, READY, DELIVERED
  totalAmount Float
  items       OrderItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  size      String? // e.g. "Small", "Medium", "Large"
  milkType  String? // e.g. "Regular", "Oat", "Almond"
  price     Float    // price at the time of purchase
}
